<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Saravi · Pedido Cierre de Campaña</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;-webkit-font-smoothing:antialiased;}
::-webkit-scrollbar{width:6px;height:6px;}
::-webkit-scrollbar-thumb{background:rgba(0,0,0,.15);border-radius:3px;}

#appLoading{position:fixed;inset:0;z-index:999;background:#1a0a2e;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;}
.spinner{width:20px;height:20px;border:2.5px solid rgba(192,132,252,.25);border-top-color:#c084fc;border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* ============================================================
   ORDER FORM (cliente) - Pedido Cierre de Campaña
   ============================================================ */
#orderScreen{
  min-height:100dvh;
  background:linear-gradient(135deg, #1a0a2e 0%, #2d1254 50%, #1a0a2e 100%);
  padding:2rem 1rem 3rem;
  position:relative;overflow:hidden;
}
.order-particles{position:absolute;inset:0;pointer-events:none;z-index:0;}
.order-particle{position:absolute;border-radius:50%;background:rgba(200,160,255,0.15);animation:ofloat linear infinite;}
@keyframes ofloat{
  0%{transform:translateY(100vh) scale(0);opacity:0;}
  10%{opacity:1;}90%{opacity:1;}
  100%{transform:translateY(-10vh) scale(1);opacity:0;}
}
.order-card{
  position:relative;z-index:1;
  max-width:480px;margin:0 auto;
  background:rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.15);
  border-radius:24px;
  padding:2.2rem 1.8rem 2.5rem;
  backdrop-filter:blur(12px);
  animation:slideUp .6s cubic-bezier(.16,1,.3,1) both;
}
@keyframes slideUp{from{opacity:0;transform:translateY(40px);}to{opacity:1;transform:translateY(0);}}
.order-logo{text-align:center;margin-bottom:1.6rem;}
.order-logo-text{
  font-family:'Playfair Display',serif;font-size:2.4rem;font-weight:700;
  background:linear-gradient(135deg,#ffffff,#e8c8ff,#c084fc);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  letter-spacing:0.12em;
}
.order-logo-sub{font-size:.7rem;color:rgba(255,255,255,.55);letter-spacing:.25em;text-transform:uppercase;margin-top:2px;}
.order-divider{display:flex;align-items:center;gap:10px;margin:0 auto 1.6rem;max-width:200px;}
.order-divider::before,.order-divider::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.25),transparent);}
.order-gem{width:6px;height:6px;background:#c084fc;border-radius:50%;box-shadow:0 0 8px #c084fc;}

/* Tipo tag — morado para Cierre de Campaña, consistente con el admin */
.order-tipo-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(192,132,252,.18);border:1px solid rgba(192,132,252,.35);border-radius:20px;padding:4px 12px;font-size:11px;font-weight:700;color:#e8c8ff;letter-spacing:.08em;text-transform:uppercase;margin-bottom:1rem;}

.product-banner{
  background:rgba(192,132,252,0.1);border:1px solid rgba(192,132,252,0.25);
  border-radius:14px;padding:14px 16px;margin-bottom:1.6rem;
  display:flex;gap:14px;align-items:center;
}
.product-banner-img{width:60px;height:60px;border-radius:10px;object-fit:cover;flex-shrink:0;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:28px;}
.product-banner-img img{width:60px;height:60px;object-fit:cover;border-radius:10px;}
.product-banner-info{flex:1;min-width:0;}
.product-banner-name{font-size:15px;font-weight:700;color:#fff;margin-bottom:4px;line-height:1.3;}
.product-banner-price{font-size:20px;font-weight:700;color:#c084fc;font-variant-numeric:tabular-nums;}
.product-banner-per{font-size:12px;color:rgba(255,255,255,.5);}

.ofield{margin-bottom:1rem;}
.ofield label{display:block;font-size:.72rem;font-weight:600;color:rgba(255,255,255,.7);letter-spacing:.05em;text-transform:uppercase;margin-bottom:5px;}
.ofield .opt{font-weight:400;text-transform:none;color:rgba(255,255,255,.4);letter-spacing:0;}
.ofield input,.ofield select,.ofield textarea{
  width:100%;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.18);
  border-radius:10px;padding:.72rem .95rem;color:#fff;font-family:'Inter',sans-serif;font-size:.9rem;
  transition:all .3s ease;outline:none;
}
.ofield input::placeholder,.ofield textarea::placeholder{color:rgba(255,255,255,.3);}
.ofield input:focus,.ofield select:focus,.ofield textarea:focus{
  border-color:rgba(192,132,252,.7);background:rgba(192,132,252,.1);box-shadow:0 0 0 3px rgba(192,132,252,.15);
}
.ofield textarea{resize:none;min-height:72px;}
.ofield-error{font-size:.7rem;color:rgba(255,140,140,.9);margin-top:3px;display:none;}
.ofield-error.vis{display:block;}
.ofield input.ferr{border-color:rgba(255,100,100,.5)!important;}

.qty-control{display:flex;align-items:center;gap:0;border:1px solid rgba(255,255,255,.2);border-radius:10px;overflow:hidden;background:rgba(255,255,255,.07);}
.qty-btn{width:44px;height:44px;display:flex;align-items:center;justify-content:center;background:none;border:none;color:#fff;font-size:22px;cursor:pointer;transition:background .2s;flex-shrink:0;}
.qty-btn:hover{background:rgba(192,132,252,.2);}
.qty-num{flex:1;text-align:center;font-size:18px;font-weight:700;color:#fff;font-variant-numeric:tabular-nums;}

.opago-group{display:flex;gap:.6rem;margin-bottom:.6rem;}
.opago-btn{
  flex:1;padding:.75rem .5rem;border-radius:10px;border:1px solid rgba(255,255,255,.18);
  background:rgba(255,255,255,.05);color:rgba(255,255,255,.6);
  font-family:'Inter',sans-serif;font-size:.82rem;cursor:pointer;transition:all .25s ease;text-align:center;font-weight:500;
}
.opago-btn:hover{border-color:rgba(255,255,255,.4);background:rgba(255,255,255,.1);color:#fff;}
.opago-btn.active{border-color:#c084fc;background:rgba(192,132,252,.18);color:#fff;box-shadow:0 0 14px rgba(192,132,252,.25);}
.opago-note{font-size:.72rem;color:rgba(255,255,255,.4);line-height:1.5;margin-bottom:1.2rem;}

.order-resumen{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);border-radius:12px;padding:1rem 1.1rem;margin-bottom:1.4rem;}
.order-res-row{display:flex;justify-content:space-between;font-size:.83rem;color:rgba(255,255,255,.55);padding:3px 0;}
.order-res-row span:last-child{color:#fff;}
.order-res-row.muted span:last-child{color:rgba(255,255,255,.45);font-style:italic;font-size:.78rem;}
.order-res-row.total{border-top:1px solid rgba(255,255,255,.12);margin-top:6px;padding-top:8px;font-weight:700;color:#fff;font-size:.95rem;}
.order-res-row.total span:last-child{color:#c084fc;font-size:1.05rem;}

.osection-title{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:.9rem;padding-left:2px;margin-top:1.4rem;}

.btn-order{
  width:100%;padding:.9rem;border-radius:12px;border:none;
  background:linear-gradient(135deg,#c084fc,#a855f7);color:#fff;font-family:'Inter',sans-serif;font-size:.95rem;
  font-weight:600;cursor:pointer;letter-spacing:.04em;transition:all .3s ease;position:relative;overflow:hidden;
}
.btn-order:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(168,85,247,.45);}
.btn-order:active{transform:translateY(0);}
.btn-order:disabled{opacity:.5;cursor:not-allowed;transform:none;}

.order-success{display:none;text-align:center;padding:2rem 0;}
.order-success-icon{
  width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#c084fc,#a855f7);
  display:flex;align-items:center;justify-content:center;margin:0 auto 1.2rem;font-size:2rem;
  box-shadow:0 0 32px rgba(168,85,247,.5);animation:popIn .5s cubic-bezier(.16,1,.3,1) both;
}
@keyframes popIn{from{transform:scale(0);opacity:0;}to{transform:scale(1);opacity:1;}}
.order-success-title{font-family:'Playfair Display',serif;font-size:1.5rem;color:#fff;margin-bottom:.8rem;}
.order-success-box{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:14px;padding:1.2rem 1.4rem;margin:1rem 0;text-align:left;}
.order-success-box h4{font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;color:rgba(255,255,255,.5);margin-bottom:.8rem;}
.order-success-box p{font-size:.88rem;color:rgba(255,255,255,.85);line-height:1.7;}
.order-success-box strong{color:#c084fc;}
.order-shipping-badge{display:inline-flex;align-items:center;gap:6px;font-size:.7rem;color:rgba(255,255,255,.35);justify-content:center;margin-top:1rem;letter-spacing:.06em;}
</style>
</head>
<body>

<div id="appLoading"><div class="spinner"></div></div>

<div id="orderScreen" style="display:none;">
  <div class="order-particles" id="orderParticles"></div>
  <div class="order-card">
    <div class="order-logo">
      <div class="order-logo-text">SARAVI</div>
      <div class="order-logo-sub">Pedido · Cierre de Campaña</div>
    </div>
    <div class="order-divider"><div class="order-gem"></div></div>

    <!-- Cargando producto -->
    <div id="orderLoading" style="text-align:center;padding:30px 0;">
      <div class="spinner" style="margin:0 auto 12px;"></div>
      <p style="color:rgba(255,255,255,.5);font-size:14px;">Cargando producto…</p>
    </div>

    <!-- Error -->
    <div id="orderError" style="display:none;text-align:center;padding:24px 0;">
      <div style="font-size:40px;margin-bottom:10px;">😕</div>
      <p style="color:rgba(255,255,255,.7);font-size:15px;">Producto no encontrado.<br>Contacta a tu vendedor.</p>
    </div>

    <!-- Formulario -->
    <div id="orderFormContent" style="display:none;">
      <div class="order-tipo-tag">📅 Cierre de Campaña</div>
      <div class="product-banner" id="productBanner"></div>

      <p class="osection-title" style="margin-top:0;">Tus datos</p>
      <div class="ofield">
        <label>Nombre completo *</label>
        <input type="text" id="oNombre" placeholder="¿Cómo te llamas?">
        <div class="ofield-error" id="oErrNombre">Ingresa tu nombre</div>
      </div>
      <div class="ofield">
        <label>Teléfono / WhatsApp *</label>
        <input type="tel" id="oTelefono" placeholder="Ej: 300 123 4567">
        <div class="ofield-error" id="oErrTelefono">Ingresa tu teléfono</div>
      </div>
      <div class="ofield">
        <label>Correo electrónico *</label>
        <input type="email" id="oCorreo" placeholder="tu@correo.com">
        <div class="ofield-error" id="oErrCorreo">Ingresa un correo válido</div>
      </div>

      <p class="osection-title">Entrega</p>
      <div class="ofield">
        <label>Ciudad *</label>
        <input type="text" id="oCiudad" placeholder="Tu ciudad">
        <div class="ofield-error" id="oErrCiudad">Ingresa la ciudad</div>
      </div>
      <div class="ofield">
        <label>Dirección <span class="opt">(opcional — la confirmamos al cierre)</span></label>
        <input type="text" id="oDireccion" placeholder="Calle, número, barrio">
      </div>
      <div class="ofield">
        <label>Nota adicional <span class="opt">(opcional)</span></label>
        <textarea id="oNota" placeholder="Color, talla, referencia, instrucciones…"></textarea>
      </div>

      <p class="osection-title">Cantidad a reservar</p>
      <div class="ofield">
        <div class="qty-control">
          <button class="qty-btn" id="qtyMinus" type="button">−</button>
          <div class="qty-num" id="qtyDisplay">1</div>
          <button class="qty-btn" id="qtyPlus" type="button">+</button>
        </div>
      </div>

      <p class="osection-title">¿Cómo prefieres pagar?</p>
      <div class="opago-group">
        <button class="opago-btn active" id="oBtnCierre" type="button">📅 El día del cierre<br><span style="font-size:.72rem;opacity:.7;">Te avisamos cuándo</span></button>
        <button class="opago-btn" id="oBtnAnticipado" type="button">💵 Anticipado<br><span style="font-size:.72rem;opacity:.7;">Transferencia ahora</span></button>
      </div>
      <p class="opago-note" id="opagoNote">Reservas tu unidad ahora y pagas cuando se cierre la campaña. Te contactaremos para confirmar el total final (incluye envío) y coordinar la entrega.</p>
      <input type="hidden" id="oMetodoPago" value="dia_cierre">

      <!-- Resumen -->
      <div class="order-resumen" id="orderResumen">
        <div class="order-res-row"><span>Precio unitario</span><span id="resUnitario">—</span></div>
        <div class="order-res-row"><span>Cantidad</span><span id="resCantidad">1</span></div>
        <div class="order-res-row muted"><span>Envío</span><span>Se define al cierre</span></div>
        <div class="order-res-row total"><span>Total a reservar</span><span id="resTotal">—</span></div>
      </div>

      <button class="btn-order" id="btnConfirmar" type="button">Confirmar reserva →</button>
      <div class="order-shipping-badge">📅 Esto es una reserva, no se cobra envío todavía</div>
    </div>

    <!-- Success -->
    <div class="order-success" id="orderSuccess">
      <div class="order-success-icon" id="orderSuccessIcon">📅</div>
      <div class="order-success-title" id="orderSuccessTitle">¡Reserva confirmada!</div>

      <!-- Pago el día del cierre -->
      <div class="order-success-box" id="successCierre" style="display:none;">
        <h4>📅 Pago el día del cierre</h4>
        <p>
          Gracias <strong id="successNombreCierre"></strong>, tu unidad quedó <strong>reservada</strong> 🎉<br><br>
          Te escribiremos cuando se cierre la campaña para confirmar el <strong>total final</strong> (incluye el envío) y los medios de pago disponibles.<br><br>
          📦 Una vez confirmes el pago, despachamos tu pedido por Interrapidísimo.
        </p>
      </div>

      <!-- Pago anticipado -->
      <div class="order-success-box" id="successAnticipado" style="display:none;">
        <h4>💳 Pago anticipado</h4>
        <p>
          ¡Gracias <strong id="successNombreAnticipado"></strong> por reservar! 🎉<br><br>
          En un instante te enviamos los <strong>medios de pago disponibles</strong> (Nequi, Daviplata, transferencia bancaria) para que adelantes tu pago.<br><br>
          📸 Recuerda enviar el comprobante; el envío se confirma y cobra cuando se cierre la campaña.
        </p>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast" style="position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(16px);background:rgba(29,29,31,.92);backdrop-filter:blur(16px);color:#fff;padding:12px 22px;border-radius:50px;font-size:14px;font-weight:500;opacity:0;pointer-events:none;transition:all .25s cubic-bezier(.4,0,.2,1);z-index:9998;max-width:90vw;text-align:center;"></div>

<script>
(function(){
  const SUPABASE_URL  = 'https://dwkuidvxqegdblablwst.supabase.co';
  const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImR3a3VpZHZ4cWVnZGJsYWJsd3N0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI0NzQ5NzcsImV4cCI6MjA5ODA1MDk3N30.6onUCOak6BHdKlCglFJQhJx0VnnjHaB3vsooNR6l8dk';
  const db = supabase.createClient(SUPABASE_URL, SUPABASE_ANON);
  const currency = new Intl.NumberFormat('es-CO',{style:'currency',currency:'COP',maximumFractionDigits:0});
  const $=sel=>document.querySelector(sel);

  function esc(str){const d=document.createElement('div');d.textContent=str==null?'':String(str);return d.innerHTML;}
  function showToast(msg){const t=$('#toast');t.textContent=msg;t.classList.add('show');t.style.opacity='1';t.style.transform='translateX(-50%) translateY(0)';clearTimeout(t._t);t._t=setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(-50%) translateY(16px)';},2800);}
  function calcPrices(p){
    const vendorPrice=(p.price||0)*(1+(p.commission||0)/100);
    const publicPrice=vendorPrice*(1+(p.margin||0)/100);
    return{vendorPrice,publicPrice,gain:vendorPrice-(p.price||0)};
  }

  let orderProduct=null, orderQty=1, orderMetodoPago='dia_cierre', orderVendorName=null;

  const urlParams=new URLSearchParams(window.location.search);
  const orderProductId=urlParams.get('order');
  const orderVendorId=urlParams.get('v');

  init();

  async function init(){
    $('#appLoading').style.display='none';
    $('#orderScreen').style.display='block';
    const pw=$('#orderParticles');
    for(let i=0;i<18;i++){
      const p=document.createElement('div');p.className='order-particle';
      const s=Math.random()*5+3;
      p.style.cssText=`width:${s}px;height:${s}px;left:${Math.random()*100}%;animation-duration:${8+Math.random()*10}s;animation-delay:${Math.random()*8}s`;
      pw.appendChild(p);
    }
    if(!orderProductId){
      $('#orderLoading').style.display='none';
      $('#orderError').style.display='block';
      return;
    }
    const{data,error}=await db.from('products').select('*').eq('id',orderProductId).single();
    $('#orderLoading').style.display='none';
    if(error||!data){$('#orderError').style.display='block';return;}
    orderProduct=data;
    orderVendorName=null;
    if(orderVendorId){
      try{const{data:vData}=await db.from('vendors').select('name').eq('id',orderVendorId).single();if(vData)orderVendorName=vData.name;}catch(e){}
    }
    orderQty=1;orderMetodoPago='dia_cierre';
    renderOrderBanner();updateOrderResumen();
    $('#orderFormContent').style.display='block';
  }

  function renderOrderBanner(){
    const p=orderProduct;const prices=calcPrices(p);
    const imgHtml=p.image?`<img src="${esc(p.image)}" style="width:60px;height:60px;object-fit:cover;border-radius:10px;flex-shrink:0;">`:`<div class="product-banner-img">🛍️</div>`;
    $('#productBanner').innerHTML=`${imgHtml}<div class="product-banner-info"><div class="product-banner-name">${esc(p.name)}</div><div class="product-banner-price">${currency.format(prices.publicPrice)}</div><div class="product-banner-per">por unidad · precio al público</div></div>`;
  }

  function updateOrderResumen(){
    if(!orderProduct)return;
    const prices=calcPrices(orderProduct);
    const total=prices.publicPrice*orderQty;
    $('#resUnitario').textContent=currency.format(prices.publicPrice);
    $('#resCantidad').textContent=orderQty;
    $('#resTotal').textContent=currency.format(total);
  }

  $('#qtyMinus').addEventListener('click',()=>{if(orderQty>1){orderQty--;$('#qtyDisplay').textContent=orderQty;updateOrderResumen();}});
  $('#qtyPlus').addEventListener('click',()=>{
    const maxStock=orderProduct?(orderProduct.stock||99):99;
    if(orderQty<maxStock){orderQty++;$('#qtyDisplay').textContent=orderQty;updateOrderResumen();}
    else showToast('No hay más unidades disponibles.');
  });

  const NOTE_CIERRE='Reservas tu unidad ahora y pagas cuando se cierre la campaña. Te contactaremos para confirmar el total final (incluye envío) y coordinar la entrega.';
  const NOTE_ANTICIPADO='Adelantas el pago por transferencia ahora. El envío se confirma y se suma al cierre de la campaña, cuando coordinemos tu entrega.';

  $('#oBtnCierre').addEventListener('click',()=>{
    orderMetodoPago='dia_cierre';$('#oBtnCierre').classList.add('active');$('#oBtnAnticipado').classList.remove('active');
    $('#oMetodoPago').value='dia_cierre';$('#opagoNote').textContent=NOTE_CIERRE;
  });
  $('#oBtnAnticipado').addEventListener('click',()=>{
    orderMetodoPago='contado';$('#oBtnAnticipado').classList.add('active');$('#oBtnCierre').classList.remove('active');
    $('#oMetodoPago').value='contado';$('#opagoNote').textContent=NOTE_ANTICIPADO;
  });

  $('#btnConfirmar').addEventListener('click', async()=>{
    if(!orderProduct)return;
    const nombre=$('#oNombre').value.trim(),telefono=$('#oTelefono').value.trim(),correo=$('#oCorreo').value.trim();
    const ciudad=$('#oCiudad').value.trim(),direccion=$('#oDireccion').value.trim(),nota=$('#oNota').value.trim();
    const metodo=$('#oMetodoPago').value;
    let ok=true;
    function chk(val,id,errId){const e=$('#'+errId),i=$('#'+id);if(!val){i.classList.add('ferr');e.classList.add('vis');ok=false;}else{i.classList.remove('ferr');e.classList.remove('vis');}}
    chk(nombre,'oNombre','oErrNombre');chk(telefono,'oTelefono','oErrTelefono');
    const emailOk=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo);
    $('#oCorreo').classList.toggle('ferr',!emailOk);$('#oErrCorreo').classList.toggle('vis',!emailOk);if(!emailOk)ok=false;
    chk(ciudad,'oCiudad','oErrCiudad');
    if(!ok)return;
    const prices=calcPrices(orderProduct);
    const total=prices.publicPrice*orderQty;
    const btn=$('#btnConfirmar');btn.disabled=true;btn.textContent='Enviando reserva…';
    try{
      const{error}=await db.from('pedidos').insert({
        product_id:orderProduct.id,product_name:orderProduct.name,
        vendor_id:orderVendorId||null,vendor_name:orderVendorName||null,
        nombre,telefono,correo,ciudad,direccion,nota,
        cantidad:orderQty,precio_unitario:prices.publicPrice,precio_publico:prices.publicPrice,
        precio_vendedor:prices.vendorPrice,ganancia_vendedor:prices.publicPrice-prices.vendorPrice,
        flete:0,total,metodo_pago:metodo,
        estado:'reservado',
        tipo_pedido:'campana'
      });
      if(error)throw error;
      $('#orderFormContent').style.display='none';
      const success=$('#orderSuccess');success.style.display='block';
      if(metodo==='dia_cierre'){$('#successCierre').style.display='block';$('#successNombreCierre').textContent=nombre;$('#orderSuccessTitle').textContent='¡Reserva confirmada!';$('#orderSuccessIcon').textContent='📅';}
      else{$('#successAnticipado').style.display='block';$('#successNombreAnticipado').textContent=nombre;$('#orderSuccessTitle').textContent='¡Gracias por tu reserva!';$('#orderSuccessIcon').textContent='💜';}
    }catch(err){showToast('❌ Error al enviar la reserva. Intenta de nuevo.');btn.disabled=false;btn.textContent='Confirmar reserva →';}
  });

})();
</script>
</body>
</html>
